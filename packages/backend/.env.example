# Connect via pooler (pgbouncer) for queries
DATABASE_URL="postgresql://postgres.xxxxxx:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connect directly for migrations
DIRECT_URL="postgresql://postgres.xxxxxx:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."   # from BotFather
JWT_SECRET="replace-with-a-long-random-string"
FRONTEND_ORIGIN="https://your-tma-frontend.vercel.app"
PORT=4000
